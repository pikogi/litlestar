# ── Google Sheets ────────────────────────────────────────────────────────────
# URL del webhook de Google Apps Script para exportar leads al Sheet
# Ver instrucciones en: app/api/submit-lead/route.ts
NEXT_PUBLIC_GOOGLE_SHEET_WEBHOOK_URL=https://script.google.com/macros/s/REEMPLAZAR/exec

# ── Mercado Pago ─────────────────────────────────────────────────────────────
# Access Token de PRODUCCIÓN
# Dónde encontrarlo: mercadopago.com.ar → Tu negocio → Configuración → Credenciales → Producción
MP_ACCESS_TOKEN=APP_USR-REEMPLAZAR

# URL base del sitio (sin barra final)
# Usada para las URLs de retorno después del pago
NEXT_PUBLIC_BASE_URL=https://tudominio.com
